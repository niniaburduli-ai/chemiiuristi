MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/chemiadvokati?retryWrites=true&w=majority"
MONGODB_DB="chemiadvokati"

AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Public site origin — canonical URLs, sitemap, robots, OpenGraph. No trailing slash.
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Google Search Console verification code (HTML-tag method). Leave blank until you have it.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# OpenRouter — get key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."
# Model that writes the human-facing answer. ":free" variants work with zero
# OpenRouter credits but are slow (forced reasoning); paid models are far faster.
OPENROUTER_ANSWER_MODEL="openai/gpt-5.2"
# Model for query understanding (keyword expansion + HyDE). Keep it fast — it
# runs on every request before retrieval.
OPENROUTER_FAST_MODEL="openai/gpt-5.2"

# Web-search enrichment (OpenRouter "web" plugin). Adds practical real-world
# context (procedures, timelines, what happens in practice) to grounded answers.
# Legal basis + citations still come ONLY from approved law text. NOTE: the web
# plugin / ":online" suffix COSTS credits (~$0.005/query); with no credits it
# returns 402 and enrichment is skipped (the answer still works).
# https://openrouter.ai/docs/guides/features/plugins/web-search
OPENROUTER_WEB_SEARCH="on"                  # "off" disables web enrichment entirely
OPENROUTER_WEB_MODEL="openai/gpt-5.2:online" # ":online" = web plugin baked in (needs credits)
OPENROUTER_WEB_ENGINE=""                            # native|exa|firecrawl|parallel|perplexity (only used for non-":online" models)
OPENROUTER_WEB_MAX_RESULTS="5"                      # 1–10 results (only used for non-":online" models; Exa ~$0.005/request)

# Flitt Payments — get keys in the Flitt merchant portal.
# Test merchant for local dev: FLITT_MERCHANT_ID=1549901, FLITT_PAYMENT_KEY=test
FLITT_MERCHANT_ID="1549901"
FLITT_PAYMENT_KEY="test"          # purchase secret key (checkout + callback signing)
FLITT_CREDIT_KEY=""               # payout/credit secret (refunds/payouts; optional)

# SMTP (Gmail) for password-reset magic links.
# Create an App Password at https://myaccount.google.com/apppasswords (needs 2FA).
SMTP_USER="your-gmail@gmail.com"  # full Gmail address that owns the app password
SMTP_PASS="your16charapppass"     # Gmail App Password (strip the spaces Google shows)
SMTP_FROM=""                      # optional From header; defaults to SMTP_USER
