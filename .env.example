MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/chemiadvokati?retryWrites=true&w=majority"
MONGODB_DB="chemiadvokati"

AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Public site origin — canonical URLs, sitemap, robots, OpenGraph. No trailing slash.
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Google Search Console verification code (HTML-tag method). Leave blank until you have it.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# OpenRouter — get key at https://openrouter.ai/keys. One key covers every
# model below (OpenAI, Google, Perplexity, etc.) — no separate provider signups.
OPENROUTER_API_KEY="sk-or-v1-..."

# --- Cost-tiered model routing -------------------------------------------
# Cheap model that writes the human-facing answer for the common case.
# Gemini 2.5 Flash: strong instruction-following (needed for the strict
# citation-format rules) and Georgian output, ~10-15x cheaper than gpt-5.2.
OPENROUTER_ANSWER_MODEL="google/gemini-2.5-flash"
# Expensive "backup" model — used ONLY when query-understanding (see below)
# flags a question as complex (spans multiple laws, ambiguous, high-stakes).
OPENROUTER_ANSWER_MODEL_COMPLEX="openai/gpt-5.2"
# Cheapest tier: query understanding (keyword expansion + HyDE + complexity
# classification, one JSON call per request, runs before retrieval). Gemini
# 2.5 Flash-Lite is fast and cheap; quality of the final prose doesn't depend
# on this model since it only extracts keywords/routes complexity.
OPENROUTER_FAST_MODEL="google/gemini-2.5-flash-lite"
# Further-savings option (rate-limited, less reliable — code already fails
# open to the raw question on any error, so this is safe to try):
# OPENROUTER_FAST_MODEL="google/gemini-2.0-flash-exp:free"

# Web-search enrichment. Adds practical real-world context (procedures,
# timelines, what happens in practice) to grounded answers. Legal basis +
# citations still come ONLY from approved law text.
# https://openrouter.ai/docs/guides/features/plugins/web-search
OPENROUTER_WEB_SEARCH="on"            # "off" disables web enrichment entirely
# Perplexity Sonar: purpose-built for grounded web search, has its own native
# search index (cheaper + faster than attaching the "web" plugin to a generic
# chat model), and OpenRouter normalizes its citations into the same
# annotations format the code already parses. Swap to "openai/gpt-4o-mini:online"
# if Sonar's Georgian phrasing isn't polished enough.
OPENROUTER_WEB_MODEL="perplexity/sonar"
OPENROUTER_WEB_ENGINE=""              # native|exa|firecrawl|parallel|perplexity (only used for non-native-search models)
OPENROUTER_WEB_MAX_RESULTS="5"        # 1–10 results (only used for non-native-search models; Exa ~$0.005/request)

# Flitt Payments — get keys in the Flitt merchant portal.
# Test merchant for local dev: FLITT_MERCHANT_ID=1549901, FLITT_PAYMENT_KEY=test
FLITT_MERCHANT_ID="1549901"
FLITT_PAYMENT_KEY="test"          # purchase secret key (checkout + callback signing)
FLITT_CREDIT_KEY=""               # payout/credit secret (refunds/payouts; optional)

# SMTP (Gmail) for password-reset magic links.
# Create an App Password at https://myaccount.google.com/apppasswords (needs 2FA).
SMTP_USER="your-gmail@gmail.com"  # full Gmail address that owns the app password
SMTP_PASS="your16charapppass"     # Gmail App Password (strip the spaces Google shows)
SMTP_FROM=""                      # optional From header; defaults to SMTP_USER
