MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/chemiadvokati?retryWrites=true&w=majority"
MONGODB_DB="chemiadvokati"

AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# OpenRouter — get key at https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."
# Model that writes the human-facing answer. Bump for higher-quality Georgian
# summaries (e.g. "openai/gpt-4o", "anthropic/claude-3.5-sonnet").
OPENROUTER_ANSWER_MODEL="openai/gpt-4o-mini"
# Cheap model for query understanding (keyword expansion + HyDE).
OPENROUTER_FAST_MODEL="openai/gpt-4o-mini"

# Flitt Payments — get keys in the Flitt merchant portal.
# Test merchant for local dev: FLITT_MERCHANT_ID=1549901, FLITT_PAYMENT_KEY=test
FLITT_MERCHANT_ID="1549901"
FLITT_PAYMENT_KEY="test"          # purchase secret key (checkout + callback signing)
FLITT_CREDIT_KEY=""               # payout/credit secret (refunds/payouts; optional)
