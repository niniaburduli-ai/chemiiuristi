# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# secret env docs (contain real keys — never commit)
VERCEL_ENV.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tesseract.js OCR language data (fetched at runtime, cached wherever the
# process CWD happens to be when no cachePath is configured)
*.traineddata

# superpowers brainstorming companion (mockup scratch files)
.superpowers/
